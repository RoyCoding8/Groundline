# Distortion Engine — Environment Variables
# Copy this file to .env and fill in the values you need.
# Real environment variables always take precedence over values in .env
# (loading uses override=False), so exporting a var wins over the file.

# Bare model name served by your OpenAI-compatible endpoint.
# Examples:
#   DISTORTION_MODEL=gpt-5.6
#   DISTORTION_MODEL=custom-model-name
DISTORTION_MODEL=

# OpenAI-compatible chat-completions endpoint base URL.
# The adapter POSTs to {DISTORTION_API_BASE}/chat/completions.
# Omit to use the default public endpoint (https://api.openai.com/v1).
# Providers without a native OpenAI-compatible surface (e.g. AWS Bedrock)
# must be reached through an OpenAI-compatible proxy set here.
# DISTORTION_API_BASE=https://your-endpoint.example.com/v1

# API key sent as `Authorization: Bearer <key>`.
# DISTORTION_API_KEY=

# Timeout and retry controls (per-decision).
# DISTORTION_TIMEOUT_SECONDS=120
# DISTORTION_MAX_ATTEMPTS=2
#
# Sampling temperature pinned to 0 by default for deterministic measurement.
# The free opencode/zen endpoint does not fully honor it, so this is a
# best-effort lever. Override only if your endpoint respects temperature.
# DISTORTION_TEMPERATURE=0.0
#
# Exponential backoff before retrying transient 5xx / transport errors.
# Seconds base; doubled per attempt up to a cap. 0 disables backoff (tests).
# DISTORTION_RETRY_BACKOFF_SECONDS=0.5
#
# Opt-in diagnostic seam: on a schema-validation failure, dump the raw
# provider content to tmp/schema-debug-*.json. Off by default (never leaks
# provider content in production runs).
# DISTORTION_DEBUG_SCHEMA=0
